{
  "name": "claude-arcade",
  "version": "0.1.0",
  "description": "Dashboard arcade gamifié + boucle d'auto-amélioration pour Claude Code. 100% local, zéro API externe.",
  "type": "module",
  "private": true,
  "scripts": {
    "scan": "bun run src/cli.ts",
    "serve": "bun run src/server/api.ts",
    "consolidate": "bun run src/consolidate/cli.ts",
    "test": "bun test",
    "typecheck": "bunx tsc --noEmit"
  },
  "dependencies": {
    "framer-motion": "^12.40.0",
    "lucide-react": "^1.17.0",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "bun-plugin-tailwind": "^0.1.2",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.7.0"
  }
}
